generator client {
  provider      = "prisma-client-js"
  // native = local dev; the musl target matches the alpine container. Adjust if the base image changes.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String? // nullable in Fase 1; populated by the auth bonus (argon2id)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  ownedTasks    Task[] @relation("TaskOwner")
  assignedTasks Task[] @relation("TaskAssignee")
}

model Task {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      Status   @default(TODO) // DB-level belt; the use-case also sets TODO server-side
  priority    Priority @default(MEDIUM)
  ownerId     String   @db.Uuid // authorization anchor for every task-by-id operation
  assigneeId  String?  @db.Uuid // nullable assignment
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  owner    User  @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  assignee User? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt]) // owner-scoped list, default sort
  @@index([ownerId, status]) // owner-scoped status filter
}
