generator client {
  provider      = "prisma-client-js"
  // native = local dev; the musl target matches the alpine container. Adjust if the base image changes.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String? // nullable in Fase 1; populated by the auth bonus (argon2id)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  boards Board[] // Fase 2: a user owns many boards (the board is the guest tenant)
  // NB: the owner-side back-relations (ownedTasks / statuses) were dropped in L1b, and the assignee
  // back-relation (assignedTasks → Task.assigneeId) in L1c-a, when Task/Status moved off User. The DB
  // columns stay until L1c-b's destructive drop (intentional schema↔DB drift).
}

// Fase 2 (L1a expand) — the collaborative tenant. A user owns many boards; each board carries an
// unguessable shareToken (the /b/<token> URL + QR). Board-scoping of Task/Status arrives additively
// here; the code cutover (ownerId → boardId) is L1b, the column drops are L1c.
model Board {
  id         String   @id @default(uuid()) @db.Uuid
  ownerId    String   @db.Uuid // the owning user (board dashboard authz anchor)
  name       String
  shareToken String   @unique // unguessable, URL-safe; the guest entry point
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks        Task[]
  statuses     Status[]
  participants Participant[]
  activities   Activity[]

  @@index([ownerId])
}

// Fase 2 (L1a expand) — a guest on a board. Identity is the opaque cookie whose sha256 lands in
// sessionTokenHash (Q5 design B — no SESSION_SECRET). L1b issues/validates the cookie; L1a only ships
// the column so no second migration is needed.
model Participant {
  id               String   @id @default(uuid()) @db.Uuid
  boardId          String   @db.Uuid
  displayName      String
  color            String? // palette token, null → neutral
  sessionTokenHash String? // sha256 of the opaque guest-session token (design B); set in L1b
  joinedAt         DateTime @default(now()) @db.Timestamptz(6)
  lastSeenAt       DateTime @default(now()) @db.Timestamptz(6)

  board         Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdTasks  Task[]     @relation("TaskCreatedBy")
  assignedTasks Task[]     @relation("TaskAssigneeParticipant")
  activities    Activity[]

  @@index([boardId])
  // NB (L1b-guest / fase2_guest_indexes): the partial UNIQUE index
  // `Participant_sessionTokenHash_key ON ("sessionTokenHash") WHERE "sessionTokenHash" IS NOT NULL`
  // is created in raw SQL in the migration — Prisma cannot express a filtered UNIQUE in the schema
  // (same limitation as the Status partial uniques above).
}

// Fase 2 (L1a expand) — append-only board audit log. taskId is a SOFT ref (no FK) so it survives task
// deletion (L3). No update/delete surface exists on the repo; append-only is the immutability control.
model Activity {
  id            String   @id @default(uuid()) @db.Uuid
  boardId       String   @db.Uuid
  participantId String?  @db.Uuid
  action        String
  taskId        String?  @db.Uuid // soft ref — intentionally NO FK
  meta          Json?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([boardId, createdAt])
}

model Status {
  id        String   @id @default(uuid()) @db.Uuid
  // ownerId column REMAINS in the DB until L1c (intentional schema↔DB drift — no migration in L1b);
  // the field + owner relation + owner-scoped indexes are dropped from the schema so the client stops
  // selecting/writing them.
  boardId   String?  @db.Uuid // Fase 2 board scope (nullable in expand; SET NOT NULL in L1c). App enforces non-null.
  name      String // display: "Staging"
  slug      String // stable key: "staging" (server-derived, dedupe)
  position  Int // column order; append-on-create
  color     String? // palette TOKEN, null → neutral
  isDefault Boolean  @default(false) // the status new tasks receive (one per scope)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  board Board? @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([boardId, slug]) // Fase 2 dedupe within board scope (protects L1b board-scoped writes)
  // NB: the per-scope single-isDefault partial unique indexes (owner + board) are created in raw SQL
  // in the migration — Prisma cannot express `WHERE "isDefault"` partial uniques in the schema.
}

model Task {
  id                     String   @id @default(uuid()) @db.Uuid
  title                  String
  description            String?
  statusId               String   @db.Uuid // FK → Status (was: status Status @default(TODO))
  priority               Priority @default(MEDIUM)
  // ownerId column REMAINS in the DB until L1c (intentional schema↔DB drift — no migration in L1b);
  // the field + owner relation + owner-scoped indexes are dropped so the client stops selecting it.
  boardId                String?  @db.Uuid // Fase 2 board scope (nullable in expand; SET NOT NULL in L1c-b). App enforces non-null.
  createdByParticipantId String?  @db.Uuid // Fase 2 attribution (guest who created the task)
  assigneeParticipantId  String?  @db.Uuid // Fase 2 assignment (→Participant; same-board check in L1b)
  position               Int      @default(0) // DnD order within a status column (used from L2b)
  createdAt              DateTime @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @db.Timestamptz(6)

  status              Status       @relation(fields: [statusId], references: [id], onDelete: Restrict) // BLOCK delete-in-use
  board               Board?       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy           Participant? @relation("TaskCreatedBy", fields: [createdByParticipantId], references: [id], onDelete: SetNull)
  assigneeParticipant Participant? @relation("TaskAssigneeParticipant", fields: [assigneeParticipantId], references: [id], onDelete: SetNull)

  @@index([assigneeParticipantId]) // L1b-guest (fase2_guest_indexes): H1 assignment lookups
}
