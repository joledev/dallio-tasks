# Copy to .env and fill with real values. The real .env* files are gitignored.
DATABASE_URL="postgresql://user:pass@localhost:5432/dallio_tasks?schema=public"
# uuid of the single seeded owner (used as actingUserId until the auth bonus). Matches prisma/seed.ts.
SEED_OWNER_ID="00000000-0000-4000-8000-000000000001"
LOG_LEVEL="info"
NODE_ENV=development
# Real-time broker (collab layer). Local dev: the docker-compose `redis` service. In-cluster: redis://redis:6379.
REDIS_URL="redis://localhost:6379"
